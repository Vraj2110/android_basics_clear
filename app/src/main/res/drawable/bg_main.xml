<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base Gradient -->
    <item>
        <shape>
            <gradient
                android:startColor="#EB434343"
                android:endColor="#EB7E7E7E"
                android:angle="135"/>
        </shape>
    </item>

    <!-- Optional subtle overlay (for depth) -->
    <item>
        <shape>
            <solid android:color="#10FFFFFF"/> <!-- light transparent white -->
        </shape>
    </item>

</layer-list>